---
import { documentsPL, documentsEN } from "../data/documents";

interface Props {
  lang?: "pl" | "en";
  compactMobile?: boolean;
}

const { lang = "pl", compactMobile = false } = Astro.props;

const documents = lang === "pl" ? documentsPL : documentsEN;

const content =
  lang === "pl"
    ? {
        eyebrow: "Dokumenty",
        title: "Ważne dokumenty w jednym miejscu",
        lead:
          "Rodzic nie powinien szukać plików po wiadomościach. Tutaj wszystko ma być czytelne, szybkie i pod ręką.",
        button: "Pobierz dokument",
        expand: "Pokaż dokument",
      }
    : {
        eyebrow: "Documents",
        title: "Important documents in one place",
        lead:
          "Parents should not search for files in messages. Everything should be clear, fast and easy to access here.",
        button: "Download document",
        expand: "Show document",
      };
---

<section class={`section documents-section ${compactMobile ? "documents-section--compact-mobile" : ""}`}>
  <div class="container">
    <div class="section-head center">
      <div class="eyebrow">{content.eyebrow}</div>
      <h2 class="section-title">{content.title}</h2>
      <p class="section-lead documents-section__lead">{content.lead}</p>
    </div>

    <div class="documents-clean-grid documents-clean-grid--desktop">
      {documents.map((doc, index) => (
        <article class={`card doc-card--clean hover-lift color-${(index % 3) + 1}`}>
          <div class="doc-card--clean__icon">PDF</div>

          <div class="doc-card--clean__body">
            <h3>{doc.title}</h3>
            <p>{doc.description}</p>
          </div>

          <a href={doc.file} class="btn btn-secondary" target="_blank" rel="noreferrer">
            {content.button}
          </a>
        </article>
      ))}
    </div>

    <div class="documents-mobile-list">
      {documents.map((doc, index) => (
        <details class={`card doc-accordion color-${(index % 3) + 1}`}>
          <summary class="doc-accordion__summary">
            <div class="doc-accordion__head">
              <div class="doc-card--clean__icon">PDF</div>
              <div>
                <strong>{doc.title}</strong>
              </div>
            </div>
            <span class="doc-accordion__toggle">{content.expand}</span>
          </summary>

          <div class="doc-accordion__content">
            <p>{doc.description}</p>
            <a href={doc.file} class="btn btn-secondary" target="_blank" rel="noreferrer">
              {content.button}
            </a>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>