---
import videoData from "../../content/videos/main.json";

interface Props {
  lang?: "pl" | "en";
}

const { lang = "pl" } = Astro.props;
const t = lang === "pl" ? videoData.pl : videoData.en;
---

<section class="section video-showcase">
  <div class="container">
    <div class="section-head center reveal">
      <div class="eyebrow">{t.eyebrow}</div>
      <h2 class="section-title">{t.title}</h2>
      <p class="section-lead">{t.lead}</p>
    </div>

    <div class="video-showcase__grid">
      {t.items.map((item) => (
        <article class="video-card reveal" data-parallax>
          <div class="video-card__badge">{item.badge}</div>

          <div class="video-shell video-shell--portrait" data-video-shell>
            <video
              class="video-shell__media"
              preload="metadata"
              controls
              playsinline
              poster={item.poster}
            >
              <source src={item.src} type="video/mp4" />
            </video>

            <button class="video-shell__play" type="button" data-video-play>
              <span class="video-shell__play-icon">▶</span>
              <span>{t.play}</span>
            </button>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const videoShells = document.querySelectorAll("[data-video-shell]");

    videoShells.forEach((shell) => {
      const video = shell.querySelector("video");
      const playBtn = shell.querySelector("[data-video-play]");

      if (!video || !playBtn) return;

      const hideButton = () => {
        shell.classList.add("is-playing");
      };

      const showButton = () => {
        if (video.paused || video.ended) {
          shell.classList.remove("is-playing");
        }
      };

      playBtn.addEventListener("click", () => {
        video.play();
        hideButton();
      });

      video.addEventListener("play", hideButton);
      video.addEventListener("pause", showButton);
      video.addEventListener("ended", showButton);
    });
  })();
</script>

<style>
  .video-showcase__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem;
    align-items: start;
  }

  .video-card {
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(16, 44, 76, 0.08);
    border-radius: 32px;
    padding: 1.4rem;
    box-shadow: 0 18px 50px rgba(16, 39, 68, 0.08);
  }

  .video-card__badge {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    background: #f4e7bc;
    color: #8a6200;
    font-weight: 800;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .video-shell {
    position: relative;
    width: min(100%, 440px);
    margin: 0 auto;
    border-radius: 28px;
    overflow: hidden;
    background: linear-gradient(180deg, #14355a, #0b2340);
    padding: 14px;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.2);
  }

  .video-shell--portrait {
    aspect-ratio: 9 / 16;
  }

  .video-shell__media {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: 22px;
    background: #08182c;
    object-fit: contain;
  }

  .video-shell__play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    border: 0;
    border-radius: 999px;
    padding: 0.95rem 1.5rem;
    background: rgba(19, 56, 97, 0.92);
    color: #fff;
    font-weight: 800;
    font-size: 1.05rem;
    box-shadow: 0 20px 48px rgba(15, 38, 68, 0.34);
    cursor: pointer;
    transition: all 0.35s ease;
  }

  .video-shell__play:hover {
    transform: translate(-50%, -50%) scale(1.04);
  }

  .video-shell__play-icon {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    display: inline-grid;
    place-items: center;
    background: #ffca28;
    color: #17324d;
    font-size: 1.2rem;
    font-weight: 900;
    box-shadow: 0 10px 25px rgba(255, 202, 40, 0.35);
  }

  .video-shell.is-playing .video-shell__play {
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, -50%) scale(0.92);
  }

  @media (max-width: 1100px) {
    .video-showcase__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .video-card {
      padding: 1rem;
      border-radius: 24px;
    }

    .video-shell {
      width: min(100%, 360px);
      padding: 10px;
      border-radius: 22px;
    }

    .video-shell__play {
      padding: 0.8rem 1.2rem;
      font-size: 0.95rem;
      gap: 0.65rem;
    }

    .video-shell__play-icon {
      width: 46px;
      height: 46px;
      font-size: 1rem;
    }
  }
</style>