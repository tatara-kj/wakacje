---
import { offers } from "../data/offers";

interface Props {
  lang?: "pl" | "en";
}

const { lang = "pl" } = Astro.props;

const formatDate = (dateStr: string) => {
  const [year, month, day] = dateStr.split("-");
  return `${day}.${month}.${year}`;
};

const formOffers = offers.map((offer) => ({
  slug: offer.slug,
  title: lang === "pl" ? offer.pl.title : offer.en.title,
  departureCity: "Częstochowa",
  terms: offer.terms.map((term) => ({
    value: `${term.start}_${term.end}`,
    label: `${term.label} • ${formatDate(term.start)} – ${formatDate(term.end)}`,
  })),
}));

const t =
  lang === "pl"
    ? {
        eyebrow: "Zapisy online",
        title: "Formularz zgłoszeniowy",
        lead:
          "Wypełnij podstawowe informacje, a organizator wróci z dalszymi szczegółami. Dane do wpłaty przekazywane są po zgłoszeniu.",
        parentName: "Imię i nazwisko rodzica",
        childName: "Imię i nazwisko dziecka",
        childAge: "Wiek dziecka",
        email: "Adres e-mail",
        phone: "Telefon kontaktowy",
        camp: "Wybierz obóz",
        term: "Wybierz termin",
        city: "Miejsce wyjazdu / miasto",
        notes: "Dodatkowe informacje",
        consent:
          "Potwierdzam, że podane dane są prawidłowe i zgadzam się na kontakt w sprawie wyjazdu.",
        submit: "Wyślij zgłoszenie",
        chooseCamp: "Wybierz obóz",
        chooseTerm: "Wybierz termin",
        firstChooseCamp: "Najpierw wybierz obóz",
      }
    : {
        eyebrow: "Online registration",
        title: "Registration form",
        lead:
          "Fill in the basic information and the organizer will contact you with further details.",
        parentName: "Parent full name",
        childName: "Child full name",
        childAge: "Child age",
        email: "E-mail",
        phone: "Phone number",
        camp: "Choose a camp",
        term: "Choose a date",
        city: "Departure city / location",
        notes: "Additional information",
        consent:
          "I confirm that the data is correct and I agree to be contacted regarding the trip.",
        submit: "Send registration",
        chooseCamp: "Choose a camp",
        chooseTerm: "Choose a date",
        firstChooseCamp: "Choose a camp first",
      };
---

<section class="section register-section" id="zapisy">
  <div class="container">
    <div class="section-head reveal">
      <div class="eyebrow">{t.eyebrow}</div>
      <h2 class="section-title">{t.title}</h2>
      <p class="section-lead">{t.lead}</p>
    </div>

    <div class="register-form-shell reveal">
<div id="formSuccessBox" class="form-success-box" style="display:none;">
  Dziękujemy. Zgłoszenie zostało wysłane. Organizator skontaktuje się w sprawie szczegółów wyjazdu, terminu oraz płatności.
</div>

      <form class="register-form-card card" id="mkRegistrationForm">
        <div class="form-grid-better">
          <div class="form-field">
            <label for="parentName">{t.parentName}</label>
            <input id="parentName" name="parentName" type="text" required />
          </div>

          <div class="form-field">
            <label for="childName">{t.childName}</label>
            <input id="childName" name="childName" type="text" required />
          </div>

          <div class="form-field">
            <label for="childAge">{t.childAge}</label>
            <input id="childAge" name="childAge" type="number" min="7" max="18" required />
          </div>

          <div class="form-field">
            <label for="email">{t.email}</label>
            <input id="email" name="email" type="email" required />
          </div>

          <div class="form-field">
            <label for="phone">{t.phone}</label>
            <input id="phone" name="phone" type="tel" required />
          </div>

          <div class="form-field">
            <label for="campSelect">{t.camp}</label>
            <select id="campSelect" name="camp" required>
              <option value="">{t.chooseCamp}</option>
              {formOffers.map((offer) => (
                <option value={offer.slug}>{offer.title}</option>
              ))}
            </select>
          </div>

          <div class="form-field form-field--full">
            <label for="termSelect">{t.term}</label>
            <select id="termSelect" name="term" required disabled>
              <option value="">{t.firstChooseCamp}</option>
            </select>
          </div>

          <div class="form-field form-field--full">
            <label for="city">{t.city}</label>
            <input id="city" name="city" type="text" readonly />
          </div>

          <div class="form-field form-field--full">
            <label for="notes">{t.notes}</label>
            <textarea id="notes" name="notes" rows="6"></textarea>
          </div>

          <div class="form-field form-field--full form-field--consent">
            <label class="checkbox-line">
              <input type="checkbox" name="consent" required />
              <span>{t.consent}</span>
            </label>
          </div>

          <div class="form-field form-field--full">
            <button type="submit" class="btn btn-primary btn-block">
              {t.submit}
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

<script is:inline define:vars={{ formOffers, t }}>
  const offersData = formOffers;
  const campSelect = document.getElementById("campSelect");
  const termSelect = document.getElementById("termSelect");
  const cityInput = document.getElementById("city");

  function renderTerms(selectedSlug) {
    if (!termSelect) return;

    const selectedOffer = offersData.find((offer) => offer.slug === selectedSlug);

    termSelect.innerHTML = "";

    if (!selectedOffer) {
      termSelect.disabled = true;
      const placeholder = document.createElement("option");
      placeholder.value = "";
      placeholder.textContent = t.firstChooseCamp;
      termSelect.appendChild(placeholder);

      if (cityInput) cityInput.value = "";
      return;
    }

    termSelect.disabled = false;

    const firstOption = document.createElement("option");
    firstOption.value = "";
    firstOption.textContent = t.chooseTerm;
    termSelect.appendChild(firstOption);

    selectedOffer.terms.forEach((term) => {
      const option = document.createElement("option");
      option.value = term.value;
      option.textContent = term.label;
      termSelect.appendChild(option);
    });

    if (cityInput) {
      cityInput.value = selectedOffer.departureCity;
    }
  }

  campSelect?.addEventListener("change", (event) => {
    renderTerms(event.target.value);
  });
  const form = document.getElementById("mkRegistrationForm");
const successBox = document.getElementById("formSuccessBox");

form?.addEventListener("submit", () => {
  setTimeout(() => {
    if (successBox) {
      successBox.style.display = "block";
      successBox.scrollIntoView({ behavior: "smooth", block: "center" });
    }
  }, 300);
});

const form = document.getElementById("mkRegistrationForm");
const successBox = document.getElementById("formSuccessBox");

form?.addEventListener("submit", () => {
  setTimeout(() => {
    if (successBox) {
      successBox.style.display = "block";
      successBox.scrollIntoView({ behavior: "smooth", block: "center" });
    }
  }, 300);
});
</script>

<style>
  .register-form-shell {
    display: flex;
    justify-content: center;
  }

  .register-form-card {
    width: min(100%, 980px);
    padding: 30px;
    border-radius: 32px;
  }

  .form-grid-better {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px 18px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .form-field--full {
    grid-column: 1 / -1;
  }

  .form-field label {
    font-size: 1rem;
    font-weight: 700;
    color: #183454;
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    min-height: 58px;
    border-radius: 18px;
    border: 1px solid rgba(18, 46, 79, 0.12);
    background: rgba(255, 255, 255, 0.94);
    padding: 14px 18px;
    font-size: 1rem;
    color: #173252;
    box-shadow: 0 10px 22px rgba(16, 39, 68, 0.04);
    appearance: none;
  }

  .form-field select,
  .form-field option {
    color: #173252 !important;
    background: #ffffff !important;
  }

  .form-field textarea {
    min-height: 150px;
    resize: vertical;
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: rgba(255, 186, 51, 0.75);
    box-shadow: 0 0 0 4px rgba(255, 206, 82, 0.18);
  }

  .checkbox-line {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.98rem;
    line-height: 1.7;
  }

  .checkbox-line input {
    margin-top: 4px;
    min-height: auto;
  }

  .btn-block {
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .form-grid-better {
      grid-template-columns: 1fr;
    }

    .form-field--full {
      grid-column: auto;
    }
  }

  @media (max-width: 640px) {
    .register-form-card {
      padding: 20px;
      border-radius: 24px;
    }
  }
</style>