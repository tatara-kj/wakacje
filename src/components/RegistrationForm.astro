---
import { offers } from "../data/offers";
import registrationData from "../../content/registration/main.json";

interface Props {
  lang?: "pl" | "en";
}

const { lang = "pl" } = Astro.props;

const formatDate = (dateStr?: string) => {
  if (!dateStr || typeof dateStr !== "string") return "";

  const [year, month, day] = dateStr.split("-");

  if (!year || !month || !day) {
    return dateStr;
  }

  return `${day}.${month}.${year}`;
};

const formOffers = offers
  .filter((offer) => offer && offer.featured !== false)
  .map((offer) => ({
    slug: offer.slug,
    title: lang === "pl" ? offer.pl.title : offer.en.title,
    departureCity: offer.departureCity || "Częstochowa",
    terms: Array.isArray(offer.terms)
      ? offer.terms
          .filter((term) => term && term.start && term.end)
          .map((term) => ({
            value: `${term.start}_${term.end}`,
            label: `${term.label || "Termin"} - ${formatDate(term.start)} - ${formatDate(term.end)}`,
          }))
      : [],
  }));

const formAction = "https://api.web3forms.com/submit";
const web3FormsAccessKey = "f1891bc0-d2c8-494a-93b8-09c276e509c6";

const t = lang === "pl" ? registrationData.pl : registrationData.en;

const childBirthDateLabel =
  lang === "pl" ? "Data urodzenia dziecka" : "Child's date of birth";
---

<section class="section register-section" id="zapisy">
  <div class="container">
    <div class="section-head reveal register-form-head">
      <div class="eyebrow">{t.formEyebrow}</div>
      <h2 class="section-title">{t.formTitle}</h2>
      <p class="section-lead">{t.formLead}</p>
    </div>

    <div class="register-form-shell reveal">
      <div
        id="formSuccessBox"
        class="form-success-box"
        style="display:none;"
        data-success={t.success}
        data-error={lang === "pl"
          ? "Nie udalo sie wyslac formularza. Sprobuj ponownie albo skontaktuj sie telefonicznie."
          : "The form could not be sent. Please try again or contact us by phone."
        }
      >
        {t.success}
      </div>

      <form
        class="register-form-card card"
        id="mkRegistrationForm"
        action={formAction}
        method="POST"
      >
        <input type="hidden" name="access_key" value={web3FormsAccessKey} />
        <input type="hidden" name="subject" value="Nowe zgloszenie MK SPORT" />
        <input type="hidden" name="from_name" value="MK SPORT - formularz zapisow" />

        <input
          type="checkbox"
          name="botcheck"
          style="display:none;"
          tabindex="-1"
          autocomplete="off"
        />

        <input type="hidden" id="selectedCampLabel" name="Wybrany oboz" value="" />
        <input type="hidden" id="selectedTermLabel" name="Wybrany termin" value="" />
        <input type="hidden" id="selectedDepartureCity" name="Miejsce wyjazdu" value="" />

        <div class="form-grid-better">
          <div class="form-field">
            <label for="parentName">{t.parentName}</label>
            <input
              id="parentName"
              name="Imie i nazwisko rodzica"
              type="text"
              autocomplete="name"
              required
            />
          </div>

          <div class="form-field">
            <label for="childName">{t.childName}</label>
            <input
              id="childName"
              name="Imie i nazwisko dziecka"
              type="text"
              required
            />
          </div>

          <div class="form-field">
            <label for="childBirthDate">{childBirthDateLabel}</label>
            <input
              id="childBirthDate"
              type="date"
              autocomplete="bday"
              required
            />
            <input
              id="childBirthDateFormatted"
              type="hidden"
              name="Data urodzenia dziecka"
              value=""
            />
          </div>

          <div class="form-field">
            <label for="email">{t.email}</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
            />
          </div>

          <div class="form-field">
            <label for="phone">{t.phone}</label>
            <input
              id="phone"
              name="Telefon kontaktowy"
              type="tel"
              autocomplete="tel"
              required
            />
          </div>

          <div class="form-field">
            <label for="campSelect">{t.camp}</label>
            <select id="campSelect" required>
              <option value="">{t.chooseCamp}</option>
              {formOffers.map((offer) => (
                <option value={offer.slug}>{offer.title}</option>
              ))}
            </select>
          </div>

          <div class="form-field form-field--full">
            <label for="termSelect">{t.term}</label>
            <select
              id="termSelect"
              required
              disabled
              data-first-option={t.firstChooseCamp}
              data-choose-option={t.chooseTerm}
            >
              <option value="">{t.firstChooseCamp}</option>
            </select>
          </div>

          <div class="form-field form-field--full">
            <label for="city">{t.city}</label>
            <input
              id="city"
              type="text"
              value=""
              readonly
            />
          </div>

          <div class="form-field form-field--full">
            <label for="notes">{t.notes}</label>
            <textarea
              id="notes"
              name="Dodatkowe informacje"
              rows="6"
            ></textarea>
          </div>

          <div class="form-field form-field--full form-field--consent">
            <label class="checkbox-line">
              <input type="checkbox" name="Zgoda na kontakt" value="Tak" required />
              <span>{t.consent}</span>
            </label>
          </div>

          <div class="form-field form-field--full">
            <button
              type="submit"
              class="btn btn-primary btn-block"
              data-sending={lang === "pl" ? "Wysylanie..." : "Sending..."}
            >
              {t.submit}
            </button>
          </div>
        </div>
      </form>

      <script type="application/json" id="mkRegistrationOffers" set:html={JSON.stringify(formOffers)} />
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const offersJson = document.getElementById("mkRegistrationOffers");
    const offersData = offersJson ? JSON.parse(offersJson.textContent || "[]") : [];

    const campSelect = document.getElementById("campSelect");
    const termSelect = document.getElementById("termSelect");
    const cityInput = document.getElementById("city");

    const selectedCampLabel = document.getElementById("selectedCampLabel");
    const selectedTermLabel = document.getElementById("selectedTermLabel");
    const selectedDepartureCity = document.getElementById("selectedDepartureCity");

    const childBirthDateInput = document.getElementById("childBirthDate");
    const childBirthDateFormatted = document.getElementById("childBirthDateFormatted");

    const form = document.getElementById("mkRegistrationForm");
    const successBox = document.getElementById("formSuccessBox");

    if (!campSelect || !termSelect) return;

    const firstChooseCampText =
      termSelect.getAttribute("data-first-option") || "Najpierw wybierz oboz";

    const chooseTermText =
      termSelect.getAttribute("data-choose-option") || "Wybierz termin";

    function makeEmailSafeText(value) {
      return String(value || "")
        .replaceAll("ą", "a")
        .replaceAll("ć", "c")
        .replaceAll("ę", "e")
        .replaceAll("ł", "l")
        .replaceAll("ń", "n")
        .replaceAll("ó", "o")
        .replaceAll("ś", "s")
        .replaceAll("ź", "z")
        .replaceAll("ż", "z")
        .replaceAll("Ą", "A")
        .replaceAll("Ć", "C")
        .replaceAll("Ę", "E")
        .replaceAll("Ł", "L")
        .replaceAll("Ń", "N")
        .replaceAll("Ó", "O")
        .replaceAll("Ś", "S")
        .replaceAll("Ź", "Z")
        .replaceAll("Ż", "Z")
        .replaceAll("•", "-")
        .replaceAll("–", "-")
        .replaceAll("—", "-");
    }

    function formatDateForEmail(dateValue) {
      if (!dateValue || typeof dateValue !== "string") return "";

      const [year, month, day] = dateValue.split("-");

      if (!year || !month || !day) {
        return dateValue;
      }

      return `${day}.${month}.${year}`;
    }

    function updateBirthDateHiddenField() {
      if (!childBirthDateInput || !childBirthDateFormatted) return;

      childBirthDateFormatted.value = formatDateForEmail(childBirthDateInput.value);
    }

    function resetTerms() {
      termSelect.innerHTML = "";

      const placeholder = document.createElement("option");
      placeholder.value = "";
      placeholder.textContent = firstChooseCampText;

      termSelect.appendChild(placeholder);
      termSelect.disabled = true;

      if (cityInput) cityInput.value = "";
      if (selectedCampLabel) selectedCampLabel.value = "";
      if (selectedTermLabel) selectedTermLabel.value = "";
      if (selectedDepartureCity) selectedDepartureCity.value = "";
    }

    function updateHiddenFields(selectedOffer) {
      const selectedCampOption = campSelect.options[campSelect.selectedIndex];
      const selectedTermOption = termSelect.options[termSelect.selectedIndex];

      if (selectedCampLabel) {
        selectedCampLabel.value = makeEmailSafeText(
          selectedCampOption?.textContent?.trim() || ""
        );
      }

      if (selectedTermLabel) {
        selectedTermLabel.value = makeEmailSafeText(
          selectedTermOption?.textContent?.trim() || ""
        );
      }

      if (selectedDepartureCity) {
        selectedDepartureCity.value = makeEmailSafeText(
          selectedOffer?.departureCity || ""
        );
      }
    }

    function renderTerms(selectedSlug) {
      const selectedOffer = offersData.find((offer) => offer.slug === selectedSlug);

      termSelect.innerHTML = "";

      if (!selectedOffer) {
        resetTerms();
        return;
      }

      termSelect.disabled = false;

      const placeholder = document.createElement("option");
      placeholder.value = "";
      placeholder.textContent = chooseTermText;
      termSelect.appendChild(placeholder);

      selectedOffer.terms.forEach((term) => {
        const option = document.createElement("option");
        option.value = term.value;
        option.textContent = term.label;
        termSelect.appendChild(option);
      });

      if (cityInput) {
        cityInput.value = selectedOffer.departureCity || "";
      }

      if (selectedDepartureCity) {
        selectedDepartureCity.value = makeEmailSafeText(
          selectedOffer.departureCity || ""
        );
      }

      if (selectedOffer.terms.length === 1) {
        termSelect.selectedIndex = 1;
      } else {
        termSelect.selectedIndex = 0;
      }

      updateHiddenFields(selectedOffer);
    }

    function showMessage(message, type = "success") {
      if (!successBox) return;

      successBox.textContent = message;
      successBox.classList.toggle("is-error", type === "error");
      successBox.style.display = "block";
      successBox.scrollIntoView({ behavior: "smooth", block: "center" });
    }

    campSelect.addEventListener("change", (event) => {
      renderTerms(event.target.value);
    });

    termSelect.addEventListener("change", () => {
      const selectedOffer = offersData.find((offer) => offer.slug === campSelect.value);
      updateHiddenFields(selectedOffer);
    });

    childBirthDateInput?.addEventListener("change", () => {
      updateBirthDateHiddenField();
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();

      const selectedOffer = offersData.find((offer) => offer.slug === campSelect.value);
      updateHiddenFields(selectedOffer);
      updateBirthDateHiddenField();

      const submitButton = form.querySelector('button[type="submit"]');
      const originalButtonText = submitButton?.textContent || "";
      const sendingButtonText =
        submitButton?.getAttribute("data-sending") || "Wysylanie...";

      if (successBox) {
        successBox.style.display = "none";
        successBox.classList.remove("is-error");
      }

      if (submitButton) {
        submitButton.textContent = sendingButtonText;
        submitButton.disabled = true;
      }

      try {
        const formData = new FormData(form);

        const response = await fetch(form.action, {
          method: "POST",
          body: formData,
          headers: {
            Accept: "application/json",
          },
        });

        const data = await response.json();

        if (!response.ok || !data.success) {
          throw new Error(data.message || "Formularz nie zostal wyslany.");
        }

        const successMessage =
          successBox?.getAttribute("data-success") ||
          "Dziekujemy, formularz zostal wyslany.";

        showMessage(successMessage, "success");

        form.reset();
        resetTerms();
        updateBirthDateHiddenField();
      } catch (error) {
        const errorMessage =
          successBox?.getAttribute("data-error") ||
          "Nie udalo sie wyslac formularza. Sprobuj ponownie.";

        showMessage(errorMessage, "error");
      } finally {
        if (submitButton) {
          submitButton.textContent = originalButtonText;
          submitButton.disabled = false;
        }
      }
    });

    resetTerms();
  })();
</script>

<style>
  .register-form-shell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .register-form-card {
    width: min(100%, 980px);
    padding: 30px;
    border-radius: 32px;
  }

  .form-success-box {
    width: min(100%, 980px);
    margin-bottom: 18px;
    padding: 16px 18px;
    border-radius: 18px;
    background: rgba(223, 255, 235, 0.88);
    border: 1px solid rgba(70, 168, 108, 0.22);
    color: #1d6134;
    font-weight: 800;
    line-height: 1.65;
    box-shadow: 0 12px 26px rgba(45, 126, 72, 0.08);
  }

  .form-success-box.is-error {
    background: rgba(255, 230, 230, 0.92);
    border-color: rgba(190, 60, 60, 0.25);
    color: #8a1f1f;
  }

  .form-grid-better {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px 18px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .form-field--full {
    grid-column: 1 / -1;
  }

  .form-field label {
    font-size: 1rem;
    font-weight: 700;
    color: #183454;
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    min-height: 58px;
    width: 100%;
    border-radius: 18px;
    border: 1px solid rgba(18, 46, 79, 0.12);
    background-color: rgba(255, 255, 255, 0.96);
    padding: 14px 18px;
    font-size: 1rem;
    color: #173252;
    box-shadow: 0 10px 22px rgba(16, 39, 68, 0.04);
  }

  .form-field select {
    appearance: auto;
    -webkit-appearance: menulist;
  }

  .form-field select,
  .form-field option {
    color: #173252 !important;
    background: #ffffff !important;
  }

  .form-field textarea {
    min-height: 150px;
    resize: vertical;
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: rgba(255, 186, 51, 0.75);
    box-shadow: 0 0 0 4px rgba(255, 206, 82, 0.18);
  }

  .checkbox-line {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.98rem;
    line-height: 1.7;
  }

  .checkbox-line input {
    width: 20px;
    height: 20px;
    min-height: auto;
    margin-top: 4px;
    flex: 0 0 auto;
  }

  .btn-block {
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .form-grid-better {
      grid-template-columns: 1fr;
    }

    .form-field--full {
      grid-column: auto;
    }
  }

  @media (max-width: 640px) {
    .register-form-card {
      padding: 20px;
      border-radius: 24px;
    }

    .form-success-box {
      border-radius: 16px;
      font-size: 0.95rem;
    }
  }
</style>