---
import faqData from "../../content/faq/main.json";

interface Props {
  lang?: "pl" | "en";
}

const { lang = "pl" } = Astro.props;
const content = lang === "pl" ? faqData.pl : faqData.en;
---

<section class="section faq-section">
  <div class="container">
    <div class="section-head center">
      <div class="eyebrow">{content.eyebrow}</div>
      <h2 class="section-title">{content.title}</h2>
      <p class="section-lead" style="margin-inline:auto;">{content.lead}</p>
    </div>

    <div class="faq-list">
      {content.items.map((item) => (
        <details class="faq-item card">
          <summary class="faq-item__summary">
            <span>{item.q}</span>
            <span class="faq-item__icon">+</span>
          </summary>
          <div class="faq-item__content">
            <p>{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>