---
import { offers } from "../data/offers";

interface Props {
  lang?: "pl" | "en";
}

const { lang = "pl" } = Astro.props;

const formatDate = (value: string) =>
  new Date(`${value}T00:00:00`).toLocaleDateString(lang === "pl" ? "pl-PL" : "en-GB", {
    day: "2-digit",
    month: "2-digit",
    year: "numeric",
  });

const allTerms = offers.flatMap((offer) =>
  offer.terms.map((term) => ({
    slug: offer.slug,
    title: lang === "pl" ? offer.pl.title : offer.en.title,
    place: lang === "pl" ? offer.pl.place : offer.en.place,
    label: term.label,
    start: term.start,
    end: term.end,
    startDate: new Date(`${term.start}T00:00:00`),
  }))
);

const now = new Date();

const nearest = allTerms
  .filter((item) => item.startDate.getTime() > now.getTime())
  .sort((a, b) => a.startDate.getTime() - b.startDate.getTime())[0] ?? null;

const t =
  lang === "pl"
    ? {
        eyebrow: "Najbliższy wyjazd",
        title: nearest ? `Odliczamy do: ${nearest.title}` : "Trwają zapisy",
        lead: nearest
          ? `${nearest.place} • ${nearest.label} • ${formatDate(nearest.start)} – ${formatDate(nearest.end)}`
          : "Najbliższe terminy pojawią się tutaj automatycznie.",
        days: "Dni",
        hours: "Godzin",
        minutes: "Minut",
        seconds: "Sekund",
      }
    : {
        eyebrow: "Next trip",
        title: nearest ? `Countdown to: ${nearest.title}` : "Registration is open",
        lead: nearest
          ? `${nearest.place} • ${nearest.label} • ${formatDate(nearest.start)} – ${formatDate(nearest.end)}`
          : "Upcoming dates will appear here automatically.",
        days: "Days",
        hours: "Hours",
        minutes: "Minutes",
        seconds: "Seconds",
      };
---

<section class="section countdown-section">
  <div class="container">
    <div class="countdown-card reveal">
      <div class="countdown-card__left">
        <div class="eyebrow">{t.eyebrow}</div>
        <h2 class="section-title">{t.title}</h2>
        <p class="section-lead">{t.lead}</p>
      </div>

      {nearest && (
        <div class="countdown-grid" data-countdown={nearest.start}>
          <div class="countdown-box">
            <strong data-days>00</strong>
            <span>{t.days}</span>
          </div>
          <div class="countdown-box">
            <strong data-hours>00</strong>
            <span>{t.hours}</span>
          </div>
          <div class="countdown-box">
            <strong data-minutes>00</strong>
            <span>{t.minutes}</span>
          </div>
          <div class="countdown-box">
            <strong data-seconds>00</strong>
            <span>{t.seconds}</span>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<script is:inline>
  const root = document.querySelector("[data-countdown]");

  if (root) {
    const target = new Date(`${root.getAttribute("data-countdown")}T00:00:00`);

    const daysEl = root.querySelector("[data-days]");
    const hoursEl = root.querySelector("[data-hours]");
    const minutesEl = root.querySelector("[data-minutes]");
    const secondsEl = root.querySelector("[data-seconds]");

    const update = () => {
      const now = new Date();
      const diff = target.getTime() - now.getTime();

      if (diff <= 0) {
        if (daysEl) daysEl.textContent = "00";
        if (hoursEl) hoursEl.textContent = "00";
        if (minutesEl) minutesEl.textContent = "00";
        if (secondsEl) secondsEl.textContent = "00";
        return;
      }

      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
      const minutes = Math.floor((diff / (1000 * 60)) % 60);
      const seconds = Math.floor((diff / 1000) % 60);

      if (daysEl) daysEl.textContent = String(days).padStart(2, "0");
      if (hoursEl) hoursEl.textContent = String(hours).padStart(2, "0");
      if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, "0");
      if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, "0");
    };

    update();
    setInterval(update, 1000);
  }
</script>