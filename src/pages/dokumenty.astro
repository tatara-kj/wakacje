---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import DocumentsSection from "../components/DocumentsSection.astro";
import FAQSection from "../components/FAQSection.astro";
---

<MainLayout title="Dokumenty" description="Dokumenty do pobrania MK SPORT" lang="pl">
  <Header lang="pl" currentPath="/dokumenty" />

  <PageHero
    eyebrow="Dokumenty"
    title="Dokumenty do pobrania"
    lead="  W tym miejscu znajdziesz wszystkie najważniejsze dokumenty potrzebne przed wyjazdem —
  szybko, wygodnie i bez szukania po wiadomościach."
  />

  <DocumentsSection lang="pl" />
  <FAQSection lang="pl" />

  <section class="section section-band">
    <div class="container">
      <div class="cta-banner card">
        <div>
          <div class="eyebrow">Kolejny krok</div>
          <h2 class="section-title">Masz już dokumenty i chcesz przejść dalej?</h2>
          <p class="section-lead">
            Przejdź do formularza zgłoszeniowego albo skontaktuj się bezpośrednio z organizatorem.
          </p>
        </div>

        <div class="cta-banner__actions">
          <a href="/zapisy" class="btn btn-primary">Przejdź do zapisów</a>
          <a href="/kontakt" class="btn btn-secondary">Kontakt</a>
        </div>
      </div>
    </div>
  </section>

  <Footer lang="pl" />
</MainLayout>