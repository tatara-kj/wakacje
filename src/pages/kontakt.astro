---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import { siteConfig } from "../data/site";
import contactData from "../../content/contact/main.json";

const contact = contactData.pl;
---

<MainLayout title="Kontakt" description="Kontakt MK SPORT" lang="pl">
  <Header lang="pl" currentPath="/kontakt" />

  <PageHero
    eyebrow={contact.pageEyebrow}
    title={contact.pageTitle}
    lead={contact.pageLead}
  />

  <section class="section">
    <div class="container">
      <div class="contact-premium">
        <div class="contact-premium__main card">
          <div class="contact-premium__top">
            <div class="eyebrow">{contact.mainEyebrow}</div>
            <h2 class="section-title">{contact.mainTitle}</h2>
            <p class="section-lead">{contact.mainLead}</p>
          </div>

          <div class="contact-premium__cards">
            <div class="contact-box card">
              <strong>{contact.phoneLabel}</strong>
              <a href={`tel:${siteConfig.phoneRaw}`}>{siteConfig.phone}</a>
              <span>{contact.phoneText}</span>
            </div>

            <div class="contact-box card">
              <strong>{contact.emailLabel}</strong>
              <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
              <span>{contact.emailText}</span>
            </div>

            <div class="contact-box card">
              <strong>{contact.ownerLabel}</strong>
              <span>{siteConfig.owner}</span>
              <span>{contact.ownerText}</span>
            </div>
          </div>

          <div class="contact-premium__actions">
            <a href="/zapisy" class="btn btn-primary">{contact.registrationButton}</a>

            {siteConfig.facebook && (
              <a href={siteConfig.facebook} target="_blank" rel="noreferrer" class="btn btn-secondary">
                Facebook
              </a>
            )}

            {siteConfig.instagram && (
              <a href={siteConfig.instagram} target="_blank" rel="noreferrer" class="btn btn-secondary">
                Instagram
              </a>
            )}
          </div>
        </div>

        <div class="contact-premium__side">
          <div class="card card-padding-lg contact-note">
            <div class="eyebrow">{contact.parentEyebrow}</div>
            <h3>{contact.parentTitle}</h3>

            <ul class="list-check">
              {contact.parentItems.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <div class="card card-padding-lg contact-note">
            <div class="eyebrow">{contact.infoEyebrow}</div>
            <h3>{contact.infoTitle}</h3>

            <p class="muted">{contact.infoText}</p>

            <p class="muted contact-formal-data">
              {siteConfig.phone}<br />
              {siteConfig.email}<br />
              {siteConfig.owner}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer lang="pl" />

  <style>
    .contact-formal-data {
      margin-top: 18px;
      font-weight: 800;
      color: #173252;
      line-height: 1.75;
      word-break: break-word;
    }
  </style>
</MainLayout>