---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import { siteConfig } from "../data/site";
import companiesData from "../../content/companies/main.json";

const page = companiesData.pl;
---

<MainLayout title="Dla firm" description="Kolonie dla dzieci pracowników MK SPORT" lang="pl">
  <Header lang="pl" currentPath="/dla-firm" />

  <PageHero
    eyebrow={page.pageEyebrow}
    title={page.pageTitle}
    lead={page.pageLead}
  />

  <section class="section companies-section">
    <div class="container">
      <div class="companies-hero card">
        <div class="companies-hero__copy">
          <div class="eyebrow">{page.sectionEyebrow}</div>
          <h2 class="section-title">{page.sectionTitle}</h2>
          <p class="section-lead">{page.sectionLead}</p>

          <div class="companies-actions">
            <a href="/kontakt" class="btn btn-primary">{page.ctaButton}</a>
            <a href="/oferta" class="btn btn-secondary">{page.secondaryButton}</a>
          </div>
        </div>

        <div class="companies-hero__image">
          <img src={page.heroImage} alt={page.heroImageAlt} />
        </div>
      </div>

      <div class="companies-features">
        {page.features.map((feature, index) => (
          <article class="companies-feature card reveal">
            <div class="companies-feature__number">{String(index + 1).padStart(2, "0")}</div>
            <h3>{feature.title}</h3>
            <p>{feature.text}</p>
          </article>
        ))}
      </div>

      <div class="companies-cta card reveal">
        <div>
          <div class="eyebrow">MK SPORT</div>
          <h2>{page.ctaTitle}</h2>
          <p>{page.ctaText}</p>
        </div>

        <div class="companies-cta__actions">
          <a href="/kontakt" class="btn btn-primary">{page.ctaButton}</a>
          <a href={`tel:${siteConfig.phoneRaw}`} class="btn btn-secondary">{siteConfig.phone}</a>
        </div>
      </div>
    </div>
  </section>

  <Footer lang="pl" />

  <style>
    .companies-section {
      overflow: hidden;
    }

    .companies-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(360px, 0.85fr);
      gap: 34px;
      align-items: center;
      padding: clamp(26px, 4vw, 54px);
      border-radius: 36px;
      background:
        radial-gradient(circle at 20% 20%, rgba(255, 202, 40, 0.18), transparent 34%),
        radial-gradient(circle at 86% 18%, rgba(120, 220, 207, 0.18), transparent 34%),
        linear-gradient(135deg, rgba(255,255,255,0.88), rgba(248,252,255,0.76));
      border: 1px solid rgba(16, 44, 76, 0.08);
      box-shadow: 0 26px 80px rgba(16, 39, 68, 0.10);
      backdrop-filter: blur(18px);
    }

    .companies-hero__copy {
      max-width: 720px;
    }

    .companies-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 26px;
    }

    .companies-hero__image {
      border-radius: 30px;
      overflow: hidden;
      box-shadow: 0 22px 60px rgba(16, 39, 68, 0.16);
      transform: rotate(1.2deg);
      background: #fff;
    }

    .companies-hero__image img {
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      display: block;
    }

    .companies-features {
      margin-top: 34px;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 18px;
    }

    .companies-feature {
      padding: 28px;
      border-radius: 30px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(16, 44, 76, 0.08);
      box-shadow: 0 18px 50px rgba(16, 39, 68, 0.08);
      backdrop-filter: blur(14px);
      transition: transform 0.28s ease, box-shadow 0.28s ease;
    }

    .companies-feature:hover {
      transform: translateY(-6px);
      box-shadow: 0 26px 70px rgba(16, 39, 68, 0.14);
    }

    .companies-feature__number {
      width: 48px;
      height: 48px;
      display: grid;
      place-items: center;
      border-radius: 18px;
      background: linear-gradient(135deg, #ffca28, #ff9f43);
      color: #173252;
      font-weight: 950;
      margin-bottom: 18px;
      box-shadow: 0 12px 28px rgba(255, 173, 43, 0.24);
    }

    .companies-feature h3 {
      margin: 0 0 10px;
      color: #173252;
      font-size: 1.25rem;
    }

    .companies-feature p {
      margin: 0;
      color: #5b7088;
      line-height: 1.7;
      font-weight: 600;
    }

    .companies-cta {
      margin-top: 34px;
      display: flex;
      justify-content: space-between;
      gap: 26px;
      align-items: center;
      padding: clamp(26px, 4vw, 46px);
      border-radius: 34px;
      background:
        linear-gradient(135deg, rgba(255,255,255,0.88), rgba(255,247,224,0.75)),
        radial-gradient(circle at 92% 20%, rgba(255, 202, 40, 0.18), transparent 34%);
      border: 1px solid rgba(16, 44, 76, 0.08);
      box-shadow: 0 22px 60px rgba(16, 39, 68, 0.08);
    }

    .companies-cta h2 {
      margin: 0 0 12px;
      color: #173252;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.05;
    }

    .companies-cta p {
      margin: 0;
      max-width: 760px;
      color: #5b7088;
      line-height: 1.7;
      font-weight: 600;
    }

    .companies-cta__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: flex-end;
    }

    @media (max-width: 1100px) {
      .companies-hero {
        grid-template-columns: 1fr;
      }

      .companies-features {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .companies-cta {
        flex-direction: column;
        align-items: flex-start;
      }

      .companies-cta__actions {
        justify-content: flex-start;
      }
    }

    @media (max-width: 640px) {
      .companies-features {
        grid-template-columns: 1fr;
      }

      .companies-hero__image {
        transform: none;
      }
    }
  </style>
</MainLayout>