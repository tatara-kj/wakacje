---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import { offers } from "../data/offers";
---

<MainLayout title="Oferta" description="Oferta obozów MK SPORT" lang="pl">
  <Header lang="pl" currentPath="/oferta" />

  <PageHero
    eyebrow="Oferta"
    title="Oferta obozów MK SPORT"
    lead="Sprawdź aktualne kierunki wyjazdów, porównaj najważniejsze informacje i wybierz odpowiednią opcję dla swojego dziecka."
  />

  <section class="section">
    <div class="container offer-detail-stack">
      {offers.map((offer, index) => {
        const content = offer.pl;
        const galleryHref = `/galeria?oboz=${offer.slug}`;

        return (
          <article class={`offer-detail card ${index % 2 === 1 ? "offer-detail--reverse" : ""}`} id={offer.slug}>
            <div class="offer-detail__image">
              <a
                href={galleryHref}
                class="offer-detail__image-link"
                aria-label={`Zobacz galerię obozu: ${content.title}`}
              >
                <img src={offer.image} alt={content.title} class="image-cover" loading="lazy" />

                <span class="offer-detail__gallery-badge">
                  Zobacz galerię
                </span>
              </a>
            </div>

            <div class="offer-detail__content">
              <div class="offer-detail__meta">
                <span class="badge">{content.season}</span>
                <span class="badge">{content.place}</span>
              </div>

              <h2 class="section-title">{content.title}</h2>
              <p class="section-lead offer-detail__lead">{content.short}</p>

              <div class="offer-detail__facts">
                <div class="offer-detail__fact">
                  <strong>Termin</strong>
                  <span>{content.date}</span>
                </div>

                <div class="offer-detail__fact">
                  <strong>Wiek uczestników</strong>
                  <span>{content.age}</span>
                </div>

                <div class="offer-detail__fact">
                  <strong>Cena</strong>
                  <span>{content.price}</span>
                </div>

                <div class="offer-detail__fact">
                  <strong>Zakwaterowanie</strong>
                  <span>{content.accommodation}</span>
                </div>

                <div class="offer-detail__fact">
                  <strong>Wyżywienie</strong>
                  <span>{content.food}</span>
                </div>

                <div class="offer-detail__fact">
                  <strong>Transport</strong>
                  <span>{content.transport}</span>
                </div>
              </div>

              <div class="grid-2 offer-detail__lists">
                <div class="card card-padding">
                  <h3>Najważniejsze atrakcje</h3>
                  <ul class="list-check">
                    {content.highlights.map((item) => <li>{item}</li>)}
                  </ul>
                </div>

                <div class="card card-padding">
                  <h3>Co obejmuje oferta</h3>
                  <ul class="list-check">
                    {content.included.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              </div>

              <div class="offer-detail__actions">
                <a href="/zapisy" class="btn btn-primary">Przejdź do zapisów</a>
                <a href="/kontakt" class="btn btn-secondary">Zadaj pytanie</a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <Footer lang="pl" />

  <style>
    .offer-detail__image {
      overflow: hidden;
    }

    .offer-detail__image-link {
      position: relative;
      display: block;
      width: 100%;
      height: 100%;
      min-height: 360px;
      overflow: hidden;
      border-radius: inherit;
      color: inherit;
      text-decoration: none;
      cursor: pointer;
    }

    .offer-detail__image-link img {
      width: 100%;
      height: 100%;
      min-height: 360px;
      object-fit: cover;
      display: block;
      transition:
        transform 0.35s ease,
        filter 0.35s ease;
    }

    .offer-detail__image-link:hover img {
      transform: scale(1.045);
      filter: brightness(0.93);
    }

    .offer-detail__gallery-badge {
      position: absolute;
      left: 18px;
      right: 18px;
      bottom: 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 46px;
      padding: 0.75rem 1.1rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
      color: #173252;
      font-weight: 900;
      font-size: 0.95rem;
      box-shadow: 0 16px 38px rgba(16, 39, 68, 0.18);
      backdrop-filter: blur(14px);
      opacity: 0;
      transform: translateY(10px);
      transition:
        opacity 0.28s ease,
        transform 0.28s ease;
      pointer-events: none;
    }

    .offer-detail__image-link:hover .offer-detail__gallery-badge {
      opacity: 1;
      transform: translateY(0);
    }

   .offer-detail__lead {
  display: block;
  max-width: 760px;
  line-height: 1.85;
  overflow: visible;
  -webkit-line-clamp: unset;
  -webkit-box-orient: initial;
}

    @media (max-width: 900px) {
      .offer-detail__image-link,
      .offer-detail__image-link img {
        min-height: 300px;
      }

      .offer-detail__gallery-badge {
        opacity: 1;
        transform: none;
      }
    }

    @media (max-width: 640px) {
      .offer-detail__image-link,
      .offer-detail__image-link img {
        min-height: 240px;
      }

      .offer-detail__gallery-badge {
        left: 12px;
        right: 12px;
        bottom: 12px;
        min-height: 40px;
        font-size: 0.86rem;
      }

     
    }
  </style>
</MainLayout>