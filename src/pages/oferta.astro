---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import { offers } from "../data/offers";
---

<MainLayout title="Oferta" description="Oferta obozów MK SPORT" lang="pl">
  <Header lang="pl" currentPath="/oferta" />

  <PageHero
    eyebrow="Oferta"
    title="Oferta obozów MK SPORT"
    lead="Sprawdź aktualne kierunki wyjazdów, porównaj najważniejsze informacje i wybierz odpowiednią opcję dla swojego dziecka."
  />

  <section class="section">
    <div class="container offer-detail-stack">
      {offers.map((offer, index) => {
        const content = offer.pl;

        return (
          <article class={`offer-detail card ${index % 2 === 1 ? "offer-detail--reverse" : ""}`} id={offer.slug}>
            <div class="offer-detail__image">
              <img src={offer.image} alt={content.title} class="image-cover" />
            </div>

            <div class="offer-detail__content">
              <div class="offer-detail__meta">
                <span class="badge">{content.season}</span>
                <span class="badge">{content.place}</span>
              </div>

              <h2 class="section-title">{content.title}</h2>
              <p class="section-lead">{content.short}</p>

              <div class="offer-detail__facts">
                <div class="offer-detail__fact">
                  <strong>Termin</strong>
                  <span>{content.date}</span>
                </div>

                <div class="offer-detail__fact">
                  <strong>Wiek uczestników</strong>
                  <span>{content.age}</span>
                </div>

                <div class="offer-detail__fact">
                  <strong>Cena</strong>
                  <span>{content.price}</span>
                </div>

                <div class="offer-detail__fact">
                  <strong>Zakwaterowanie</strong>
                  <span>{content.accommodation}</span>
                </div>

                <div class="offer-detail__fact">
                  <strong>Wyżywienie</strong>
                  <span>{content.food}</span>
                </div>

                <div class="offer-detail__fact">
                  <strong>Transport</strong>
                  <span>{content.transport}</span>
                </div>
              </div>

              <div class="grid-2 offer-detail__lists">
                <div class="card card-padding">
                  <h3>Najważniejsze atrakcje</h3>
                  <ul class="list-check">
                    {content.highlights.map((item) => <li>{item}</li>)}
                  </ul>
                </div>

                <div class="card card-padding">
                  <h3>Co obejmuje oferta</h3>
                  <ul class="list-check">
                    {content.included.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              </div>

              <div class="offer-detail__actions">
                <a href="/zapisy" class="btn btn-primary">Przejdź do zapisów</a>
                <a href="/kontakt" class="btn btn-secondary">Zadaj pytanie</a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <Footer lang="pl" />
</MainLayout>