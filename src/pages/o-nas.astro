---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import aboutData from "../../content/about/main.json";

const about = aboutData.pl;
---

<MainLayout title="O nas" description="O MK SPORT" lang="pl">
  <Header lang="pl" currentPath="/o-nas" />

  <PageHero
    eyebrow={about.pageEyebrow}
    title={about.pageTitle}
    lead={about.pageLead}
  />

  <section class="section about-page-section">
    <div class="container">
      <div class="about-premium about-premium--clean">
        <div class="about-premium__media reveal">
          <div class="about-premium__media-frame">
            <img
              src={about.image}
              alt={about.imageAlt}
              class="about-premium__image about-premium__image--contain"
            />
          </div>
        </div>

        <div class="about-premium__content reveal">
          <div class="about-copy-card">
            <div class="eyebrow">{about.eyebrow}</div>
            <h2 class="section-title">{about.title}</h2>

            {about.paragraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer lang="pl" />

  <style>
    .about-premium--clean {
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
      gap: 22px;
      align-items: stretch;
    }

    .about-premium__media-frame {
      height: 100%;
      min-height: 760px;
      display: grid;
      place-items: center;
      padding: 26px;
      border-radius: 32px;
      background: rgba(255, 255, 255, 0.76);
      box-shadow: 0 22px 60px rgba(16, 39, 68, 0.08);
      backdrop-filter: blur(14px);
      overflow: hidden;
    }

    .about-premium__image--contain {
      max-width: 100%;
      max-height: 100%;
      width: auto;
      height: auto;
      display: block;
      object-fit: contain;
      object-position: center center;
      border-radius: 24px;
    }

    @media (max-width: 980px) {
      .about-premium--clean {
        grid-template-columns: 1fr;
      }

      .about-premium__media-frame {
        min-height: 520px;
      }
    }

    @media (max-width: 768px) {
      .about-premium__media-frame {
        min-height: 380px;
        padding: 16px;
        border-radius: 24px;
      }

      .about-premium__image--contain {
        border-radius: 18px;
      }
    }
  </style>
</MainLayout>