---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import RegistrationForm from "../components/RegistrationForm.astro";
import FAQSection from "../components/FAQSection.astro";
import ProcessSection from "../components/ProcessSection.astro";
import { siteConfig } from "../data/site";
import registrationData from "../../content/registration/main.json";

const registration = registrationData.pl;
---

<MainLayout title="Zapisy" description="Formularz zapisów MK SPORT" lang="pl">
  <Header lang="pl" currentPath="/zapisy" />

  <PageHero
    eyebrow={registration.pageEyebrow}
    title={registration.pageTitle}
    lead={registration.pageLead}
  />

  <section class="section">
    <div class="container">
      <div class="registration-premium">
        <div class="registration-premium__form">
          <RegistrationForm lang="pl" />
        </div>

        <div class="registration-premium__side">
          <div class="card card-padding-lg register-info-card">
            <div class="eyebrow">{registration.sideProcessEyebrow}</div>
            <h3>{registration.sideProcessTitle}</h3>

            <ul class="list-check">
              {registration.sideProcessItems.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <div class="card card-padding-lg register-info-card">
            <div class="eyebrow">{registration.sideContactEyebrow}</div>
            <h3>{registration.sideContactTitle}</h3>
            <p class="muted">{registration.sideContactText}</p>

            <div class="register-contact-list">
              <a href={`tel:${siteConfig.phoneRaw}`}>{siteConfig.phone}</a>
              <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
              <span>{siteConfig.owner}</span>
            </div>

            <div style="margin-top:18px;">
              <a href="/kontakt" class="btn btn-secondary">{registration.sideContactButton}</a>
            </div>
          </div>

          <div class="card card-padding-lg register-info-card">
            <div class="eyebrow">{registration.sideImportantEyebrow}</div>
            <h3>{registration.sideImportantTitle}</h3>
            <p class="muted">{registration.sideImportantText}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ProcessSection lang="pl" />
  <FAQSection lang="pl" />

  <Footer lang="pl" />
</MainLayout>