---
import fs from "node:fs";
import path from "node:path";
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";

const root = process.cwd();

const gallerySections = [
  {
    folder: "jaroslawiec",
    title: "Jarosławiec",
    subtitle: "Nadmorski klimat, aktywność i wakacyjna energia",
    description:
      "Zdjęcia z Jarosławca pokazują nadmorski klimat wyjazdu, wspólne aktywności, integrację i codzienną radość dzieci podczas kolonii.",
  },
  {
    folder: "ostrow-pieckowskie",
    title: "Ostrów Pieckowskie",
    subtitle: "Mazury, jezioro i aktywny wypoczynek",
    description:
      "Mazury pokazują przestrzeń, naturę i spokojniejszy rytm wyjazdu, ale nadal pełen aktywności i wspólnych atrakcji.",
  },
  {
    folder: "poronin-zimowy",
    title: "Poronin",
    subtitle: "Górski klimat, ruch i zimowe atrakcje",
    description:
      "Tutaj wchodzą zimowe kadry, góry, integracja i wspólne aktywności podczas zimowiska.",
  },
];

function readImages(folder: string) {
  const dir = path.join(root, "public", "images", folder);

  if (!fs.existsSync(dir)) {
    return [];
  }

  const priority = (name: string) => {
    const lower = name.toLowerCase();

    if (lower.startsWith("main.")) return 0;
    if (lower.startsWith("1.")) return 1;

    return 2;
  };

  return fs
    .readdirSync(dir)
    .filter((name) => /\.(jpg|jpeg|jfif|png|webp)$/i.test(name))
    .sort((a, b) => priority(a) - priority(b) || a.localeCompare(b, "pl"))
    .map((name) => `/images/${folder}/${name}`);
}

const sections = gallerySections
  .map((section) => ({
    ...section,
    images: readImages(section.folder),
  }))
  .filter((section) => section.images.length > 0);
---

<MainLayout title="Galeria" description="Galeria MK SPORT" lang="pl">
  <Header lang="pl" currentPath="/galeria" />

  <PageHero
    eyebrow="Galeria"
    title="Zobacz klimat naszych wyjazdów"
    lead="Zdjęcia pokazują miejsca, atmosferę grupy i charakter każdego wyjazdu."
  />

  {sections.length === 0 ? (
    <section class="section">
      <div class="container">
        <div class="gallery-empty card">
          <div class="eyebrow">Galeria</div>
          <h2 class="section-title">Brak zdjęć w galerii</h2>
          <p class="section-lead">
            Sprawdź, czy zdjęcia są w folderach: jaroslawiec, ostrow-pieckowskie i poronin-zimowy.
          </p>
        </div>
      </div>
    </section>
  ) : (
    sections.map((section) => {
      const preview = section.images.slice(0, 8);

      return (
        <section class="section gallery-auto-section">
          <div class="container">
            <div class="gallery-band gallery-band--fixed">
              <div class="gallery-intro-card card card-padding-lg">
                <div class="eyebrow">Galeria</div>
                <h2 class="section-title">{section.title}</h2>
                <p class="section-lead">{section.subtitle}</p>
                <p class="gallery-section-description">{section.description}</p>
              </div>

              <div class="gallery-preview-grid gallery-preview-grid--better">
                {preview.map((src, index) => (
                  <button
                    class={`gallery-preview-grid__item card ${index === 0 ? "is-featured" : ""}`}
                    data-lightbox-image={src}
                    data-lightbox-title={section.title}
                    type="button"
                  >
                    <img src={src} alt={section.title} loading="lazy" />

                    <span class="gallery-preview-grid__caption">
                      <strong>{section.title}</strong>
                      <small>{section.subtitle}</small>
                    </span>
                  </button>
                ))}
              </div>

              {section.images.length > 8 && (
                <details class="gallery-expand card">
                  <summary>
                    <span>Pokaż pełną galerię — {section.images.length} zdjęć</span>
                  </summary>

                  <div class="gallery-wall gallery-wall--expanded">
                    {section.images.map((src) => (
                      <button
                        class="gallery-wall__item card"
                        data-lightbox-image={src}
                        data-lightbox-title={section.title}
                        type="button"
                      >
                        <img src={src} alt={section.title} loading="lazy" />
                      </button>
                    ))}
                  </div>
                </details>
              )}
            </div>
          </div>
        </section>
      );
    })
  )}

  <dialog class="lightbox-dialog" id="lightboxDialog">
    <button class="lightbox-close" id="lightboxClose" type="button">✕</button>
    <img id="lightboxImage" alt="" />
    <div class="lightbox-caption" id="lightboxCaption"></div>
  </dialog>

  <script is:inline>
    const dialog = document.getElementById("lightboxDialog");
    const dialogImage = document.getElementById("lightboxImage");
    const dialogCaption = document.getElementById("lightboxCaption");
    const dialogClose = document.getElementById("lightboxClose");

    document.querySelectorAll("[data-lightbox-image]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const src = btn.getAttribute("data-lightbox-image");
        const title = btn.getAttribute("data-lightbox-title") || "";

        if (!src || !dialog || !dialogImage || !dialogCaption) return;

        dialogImage.src = src;
        dialogImage.alt = title;
        dialogCaption.textContent = title;
        dialog.showModal();
      });
    });

    dialogClose?.addEventListener("click", () => dialog?.close());

    dialog?.addEventListener("click", (event) => {
      const rect = dialog.getBoundingClientRect();

      const isInside =
        rect.top <= event.clientY &&
        event.clientY <= rect.top + rect.height &&
        rect.left <= event.clientX &&
        event.clientX <= rect.left + rect.width;

      if (!isInside) {
        dialog.close();
      }
    });
  </script>

  <Footer lang="pl" />

  <style>
    .gallery-empty {
      max-width: 900px;
      margin-inline: auto;
      padding: clamp(28px, 4vw, 52px);
      text-align: center;
      border-radius: 34px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(16, 44, 76, 0.08);
      box-shadow: 0 22px 60px rgba(16, 39, 68, 0.08);
      backdrop-filter: blur(16px);
    }

    .gallery-auto-section {
      position: relative;
    }

    .gallery-band--fixed {
      display: grid;
      gap: 28px;
      width: 100%;
    }

    .gallery-intro-card {
      max-width: 980px;
      margin-inline: auto;
      text-align: center;
      border-radius: 34px;
      background:
        linear-gradient(135deg, rgba(255,255,255,0.9), rgba(248,252,255,0.78)),
        radial-gradient(circle at 15% 20%, rgba(255, 202, 40, 0.16), transparent 36%),
        radial-gradient(circle at 85% 15%, rgba(117, 220, 206, 0.14), transparent 35%);
      border: 1px solid rgba(16, 44, 76, 0.08);
      box-shadow: 0 22px 60px rgba(16, 39, 68, 0.08);
      backdrop-filter: blur(16px);
    }

    .gallery-section-description {
      max-width: 760px;
      margin: 16px auto 0;
      color: #5d728a;
      line-height: 1.8;
      font-weight: 600;
    }

    .gallery-preview-grid--better {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 18px;
      align-items: stretch;
    }

    .gallery-preview-grid__item {
      position: relative;
      min-height: 240px;
      overflow: hidden;
      border-radius: 28px;
      padding: 0;
      border: 1px solid rgba(16, 44, 76, 0.08);
      box-shadow: 0 18px 42px rgba(16, 39, 68, 0.08);
      cursor: pointer;
      background: #fff;
    }

    .gallery-preview-grid__item img {
      width: 100%;
      height: 100%;
      min-height: 240px;
      object-fit: cover;
      display: block;
      transition: transform 0.35s ease;
    }

    .gallery-preview-grid__item:hover img {
      transform: scale(1.04);
    }

    .gallery-preview-grid__item.is-featured {
      grid-column: span 2;
      grid-row: span 2;
      min-height: 500px;
    }

    .gallery-preview-grid__item.is-featured img {
      min-height: 500px;
    }

    .gallery-preview-grid__caption {
      position: absolute;
      left: 14px;
      right: 14px;
      bottom: 14px;
      display: grid;
      gap: 4px;
      padding: 14px 16px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.86);
      backdrop-filter: blur(14px);
      box-shadow: 0 14px 35px rgba(16, 39, 68, 0.14);
      color: #173252;
      text-align: left;
    }

    .gallery-preview-grid__caption small {
      color: #60748c;
      font-weight: 700;
      line-height: 1.35;
    }

    .gallery-expand {
      padding: 22px;
      border-radius: 28px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(16, 44, 76, 0.08);
      box-shadow: 0 18px 50px rgba(16, 39, 68, 0.07);
    }

    .gallery-expand summary {
      cursor: pointer;
      font-weight: 900;
      color: #173252;
      list-style: none;
    }

    .gallery-expand summary::-webkit-details-marker {
      display: none;
    }

    .gallery-wall--expanded {
      margin-top: 22px;
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 14px;
    }

    .gallery-wall__item {
      padding: 0;
      border: 0;
      overflow: hidden;
      border-radius: 20px;
      min-height: 160px;
      cursor: pointer;
      background: #fff;
    }

    .gallery-wall__item img {
      width: 100%;
      height: 100%;
      min-height: 160px;
      object-fit: cover;
      display: block;
      transition: transform 0.35s ease;
    }

    .gallery-wall__item:hover img {
      transform: scale(1.04);
    }

    .lightbox-dialog {
      width: min(92vw, 1100px);
      border: 0;
      border-radius: 28px;
      padding: 18px;
      background: rgba(255, 255, 255, 0.94);
      box-shadow: 0 28px 90px rgba(0, 0, 0, 0.28);
    }

    .lightbox-dialog::backdrop {
      background: rgba(6, 18, 35, 0.72);
      backdrop-filter: blur(8px);
    }

    .lightbox-dialog img {
      width: 100%;
      max-height: 78vh;
      object-fit: contain;
      display: block;
      border-radius: 20px;
      background: #eef3f8;
    }

    .lightbox-close {
      position: absolute;
      right: 18px;
      top: 18px;
      z-index: 2;
      width: 42px;
      height: 42px;
      border: 0;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
      cursor: pointer;
      font-weight: 900;
      color: #173252;
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.16);
    }

    .lightbox-caption {
      margin-top: 12px;
      text-align: center;
      font-weight: 800;
      color: #173252;
    }

    @media (max-width: 1100px) {
      .gallery-preview-grid--better {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .gallery-wall--expanded {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .gallery-preview-grid--better {
        grid-template-columns: 1fr;
      }

      .gallery-preview-grid__item,
      .gallery-preview-grid__item.is-featured,
      .gallery-preview-grid__item img,
      .gallery-preview-grid__item.is-featured img {
        min-height: 320px;
      }

      .gallery-wall--expanded {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
  </style>
</MainLayout>